# Copy to .env and fill in. The real .env is gitignored.

# MongoDB connection string. Local example:
#   mongodb://localhost:27017/cufinder
# Atlas example:
#   mongodb+srv://user:pass@cluster.mongodb.net/cufinder
MONGODB_URI=mongodb://localhost:27017/cufinder

# Long random string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# Allowed CORS origin for the frontend. Vite dev defaults to 5173.
FRONTEND_ORIGIN=http://localhost:5173

# Selects config class. dev = DevConfig (cookies non-Secure, debug-friendly).
# Set to "prod" on the deploy host.
APP_ENV=dev
