# Copy to .env and fill in. The real .env is gitignored.

# MongoDB connection string. Local example:
#   mongodb://localhost:27017/cufinder
# Atlas example:
#   mongodb+srv://user:pass@cluster.mongodb.net/cufinder
MONGODB_URI=mongodb://localhost:27017/cufinder

# Long random string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# Allowed CORS origin for the frontend. Vite dev defaults to 5173.
FRONTEND_ORIGIN=http://localhost:5173

# Google OAuth credentials.
# Create at https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID.
# Authorised redirect URI to register: http://localhost:5001/api/auth/callback (dev)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/callback

# Selects config class. dev = DevConfig (cookies non-Secure, debug-friendly).
# Set to "prod" on the deploy host.
APP_ENV=dev
