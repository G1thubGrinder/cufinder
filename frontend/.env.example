# When true, the frontend uses in-memory fake data instead of calling the backend.
# Useful while the Flask side is still being built.
VITE_USE_MOCK=true

# When VITE_USE_MOCK=false and this is empty, requests use relative /api/...
# paths via the Vite dev proxy (see vite.config.ts) — fine for local dev.
# For a split-origin deploy (e.g. Vercel frontend + Render backend), set this
# to the absolute backend origin so XHRs and the OAuth redirect target it.
# VITE_API_BASE_URL=https://your-backend.onrender.com
